{
  "buildCommand": "node deployment/inject-config.js",
  "outputDirectory": ".",
  "cleanUrls": true,
  "redirects": [
    { "source": "/", "destination": "/welcome.html", "permanent": false }
  ],
  "functions": {
    "api/llm/*.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/payment/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
